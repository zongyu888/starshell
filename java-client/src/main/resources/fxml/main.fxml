<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.aifinalshell.controller.MainController"
            prefWidth="1400" prefHeight="850"
            style="-fx-background-color: #1e1e1e;">

    <!-- ========== Top Toolbar ========== -->
    <top>
        <ToolBar style="-fx-background-color: #252526; -fx-border-color: #3c3c3c;">
            <Button fx:id="leftCollapseBtn" text="◀" onAction="#toggleLeftPanel"
                    style="-fx-background-color: transparent; -fx-text-fill: #0dbc79; -fx-font-size: 12px; -fx-padding: 4 6; -fx-cursor: hand;"/>
            <Button text="%toolbar.servers" onAction="#showServerManager" styleClass="toolbar-btn"/>
            <Button text="%toolbar.connect" onAction="#connectSelectedServer" styleClass="toolbar-btn"/>
            <Button text="%toolbar.disconnect" onAction="#disconnectServer" styleClass="toolbar-btn"/>
            <Button text="%toolbar.transfer" onAction="#showTransferManager" styleClass="toolbar-btn"/>
            <Button text="%toolbar.settings" onAction="#showSettings" styleClass="toolbar-btn"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="rightCollapseBtn" text="▶" onAction="#toggleRightPanel"
                    style="-fx-background-color: transparent; -fx-text-fill: #2472c8; -fx-font-size: 12px; -fx-padding: 4 6; -fx-cursor: hand;"/>
            <Label fx:id="aiConnectionStatus" text="Offline" style="-fx-text-fill: #cd3131; -fx-font-size: 11px;"/>
        </ToolBar>
    </top>

    <!-- ========== Center: Left Panel + Main Content + Right Panel ========== -->
    <center>
        <SplitPane fx:id="mainSplitPane" dividerPositions="0.18, 0.65" orientation="HORIZONTAL"
                   style="-fx-background-color: #1e1e1e;">

            <!-- ===== Left Panel ===== -->
            <VBox fx:id="leftPanel" prefWidth="260" minWidth="200" spacing="0"
                  style="-fx-background-color: #252526; -fx-border-color: #3c3c3c; -fx-border-width: 0 1 0 0;">
                <VBox fx:id="leftContent" VBox.vgrow="ALWAYS" spacing="0" style="-fx-background-color: #252526;">

                    <!-- 面板标题栏：含面板内收纳按钮（与右面板 ✕ 对称） -->
                    <HBox spacing="8" alignment="CENTER_LEFT" styleClass="left-panel-header">
                        <Label text="%left.title" styleClass="left-panel-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="leftCollapseInBtn" text="◀" onAction="#toggleLeftPanel" styleClass="left-collapse-btn"/>
                    </HBox>

                    <!-- Connected Server Info -->
                    <VBox fx:id="serverInfoPanel" spacing="6" styleClass="server-info-box">
                        <HBox spacing="6" alignment="CENTER_LEFT">
                            <Label text="IP" styleClass="server-info-key"/>
                            <Label fx:id="connectedIpLabel" text="--" styleClass="server-info-ip" HBox.hgrow="ALWAYS"/>
                            <Button fx:id="copyIpBtn" text="⧉" onAction="#copyServerIp" styleClass="icon-btn"/>
                        </HBox>
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="server-info-sys-row" onMouseClicked="#showSystemInfo">
                            <Label text="SYS" styleClass="server-info-key"/>
                            <Label fx:id="sysInfoBrief" text="%left.click_for_details" styleClass="server-info-sys" HBox.hgrow="ALWAYS"/>
                            <Label text="▸" styleClass="server-info-arrow"/>
                        </HBox>
                    </VBox>

                    <!-- Status Section -->
                    <VBox fx:id="statusSection">
                        <HBox fx:id="statusHeader" spacing="6" alignment="CENTER_LEFT" styleClass="monitor-section-header" onMouseClicked="#toggleStatusSection">
                            <Label fx:id="statusArrow" text="▾" styleClass="monitor-section-arrow"/>
                            <Label text="%left.section.status" styleClass="monitor-section-title monitor-title-status"/>
                        </HBox>
                        <VBox fx:id="statusContent" spacing="4" styleClass="monitor-section-content">
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="status-row">
                                <Label text="%left.uptime" styleClass="status-key"/>
                                <Label fx:id="uptimeLabel" text="--" styleClass="status-value" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="status-row">
                                <Label text="%left.load" styleClass="status-key"/>
                                <Label fx:id="loadLabel" text="-- / -- / --" styleClass="status-value" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="status-row">
                                <Label text="%left.ping" styleClass="status-key"/>
                                <Label fx:id="pingLabel" text="-- ms" styleClass="status-value status-value-good" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="status-row">
                                <Label text="%left.procs" styleClass="status-key"/>
                                <Label fx:id="procsLabel" text="--" styleClass="status-value" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Monitor Section -->
                    <VBox fx:id="monitorSection">
                        <HBox fx:id="monitorHeader" spacing="6" alignment="CENTER_LEFT" styleClass="monitor-section-header" onMouseClicked="#toggleMonitorSection">
                            <Label fx:id="monitorArrow" text="▾" styleClass="monitor-section-arrow"/>
                            <Label text="%left.section.monitor" styleClass="monitor-section-title monitor-title-monitor"/>
                        </HBox>
                        <VBox fx:id="monitorContent" spacing="6" styleClass="monitor-section-content">
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="monitor-row">
                                <Label text="CPU" styleClass="monitor-row-key"/>
                                <ProgressBar fx:id="cpuBar" progress="0" HBox.hgrow="ALWAYS" styleClass="monitor-progress monitor-bar-cpu"/>
                                <Label fx:id="cpuLabel" text="--%" styleClass="monitor-row-value monitor-value-cpu"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="monitor-row">
                                <Label text="MEM" styleClass="monitor-row-key"/>
                                <ProgressBar fx:id="memBar" progress="0" HBox.hgrow="ALWAYS" styleClass="monitor-progress monitor-bar-mem"/>
                                <Label fx:id="memLabel" text="--%" styleClass="monitor-row-value monitor-value-mem"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="monitor-row">
                                <Label text="DISK" styleClass="monitor-row-key"/>
                                <ProgressBar fx:id="diskBar" progress="0" HBox.hgrow="ALWAYS" styleClass="monitor-progress monitor-bar-disk"/>
                                <Label fx:id="diskLabel" text="--%" styleClass="monitor-row-value monitor-value-disk"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Top Processes Section -->
                    <VBox fx:id="topProcSection">
                        <HBox fx:id="topProcHeader" spacing="6" alignment="CENTER_LEFT" styleClass="monitor-section-header" onMouseClicked="#toggleTopProcSection">
                            <Label fx:id="topProcArrow" text="▾" styleClass="monitor-section-arrow"/>
                            <Label text="%left.section.top" styleClass="monitor-section-title monitor-title-top"/>
                        </HBox>
                        <VBox fx:id="topProcContent" styleClass="monitor-section-content">
                            <TableView fx:id="topProcessTable" editable="false" prefHeight="105" VBox.vgrow="ALWAYS" styleClass="top-process-table">
                                <columns>
                                    <TableColumn fx:id="topUserCol" text="USER" styleClass="top-col-user" prefWidth="60"/>
                                    <TableColumn fx:id="topCpuCol" text="CPU%" styleClass="top-col-cpu" prefWidth="46"/>
                                    <TableColumn fx:id="topMemCol" text="MEM%" styleClass="top-col-mem" prefWidth="46"/>
                                    <TableColumn fx:id="topCmdCol" text="COMMAND" styleClass="top-col-cmd" prefWidth="100"/>
                                </columns>
                                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                            </TableView>
                        </VBox>
                    </VBox>

                    <!-- Network Section -->
                    <VBox fx:id="networkSection">
                        <HBox fx:id="networkHeader" spacing="6" alignment="CENTER_LEFT" styleClass="monitor-section-header" onMouseClicked="#toggleNetworkSection">
                            <Label fx:id="networkArrow" text="▾" styleClass="monitor-section-arrow"/>
                            <Label text="%left.section.network" styleClass="monitor-section-title monitor-title-network"/>
                        </HBox>
                        <VBox fx:id="networkContent" spacing="6" styleClass="monitor-section-content">
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="monitor-row">
                                <Label text="↑" styleClass="net-up-arrow"/>
                                <Label fx:id="netUpLabel" text="-- KB/s" styleClass="net-value-up" HBox.hgrow="ALWAYS"/>
                                <ProgressBar fx:id="netUpBar" progress="0" prefWidth="70" styleClass="monitor-progress monitor-bar-cpu net-bar"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="monitor-row">
                                <Label text="↓" styleClass="net-down-arrow"/>
                                <Label fx:id="netDownLabel" text="-- KB/s" styleClass="net-value-down" HBox.hgrow="ALWAYS"/>
                                <ProgressBar fx:id="netDownBar" progress="0" prefWidth="70" styleClass="monitor-progress monitor-bar-mem net-bar"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Disk Section -->
                    <VBox fx:id="diskSection">
                        <HBox fx:id="diskHeader" spacing="6" alignment="CENTER_LEFT" styleClass="monitor-section-header" onMouseClicked="#toggleDiskSection">
                            <Label fx:id="diskArrow" text="▾" styleClass="monitor-section-arrow"/>
                            <Label text="%left.section.disk" styleClass="monitor-section-title monitor-title-disk"/>
                        </HBox>
                        <VBox fx:id="diskContent" spacing="6" styleClass="monitor-section-content">
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="monitor-row">
                                <Label text="/" styleClass="monitor-row-key"/>
                                <ProgressBar fx:id="diskDetailBar" progress="0" HBox.hgrow="ALWAYS" styleClass="monitor-progress monitor-bar-disk"/>
                                <Label fx:id="diskFreeLabel" text="--" styleClass="monitor-row-value"/>
                            </HBox>
                        </VBox>
                    </VBox>

                    <!-- Log Section -->
                    <VBox fx:id="logSection">
                        <HBox fx:id="logHeader" spacing="6" alignment="CENTER_LEFT" styleClass="monitor-section-header" onMouseClicked="#toggleLogSection">
                            <Label fx:id="logArrow" text="▾" styleClass="monitor-section-arrow"/>
                            <Label text="%left.section.log" styleClass="monitor-section-title monitor-title-log"/>
                        </HBox>
                        <VBox fx:id="logContent" spacing="4" styleClass="monitor-section-content">
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="status-row">
                                <Label text="%left.path" styleClass="status-key"/>
                                <Label fx:id="logPathLabel" text="--" styleClass="status-value" HBox.hgrow="ALWAYS"/>
                            </HBox>
                            <HBox spacing="6" alignment="CENTER_LEFT" styleClass="status-row">
                                <Label text="%left.errors" styleClass="status-key"/>
                                <Label fx:id="logErrorLabel" text="0" styleClass="status-value status-value-error" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </VBox>
            </VBox>

            <!-- ===== Center: Sessions + Terminal + Files ===== -->
            <SplitPane fx:id="centerSplitPane" dividerPositions="0.6" orientation="VERTICAL"
                       style="-fx-background-color: #1e1e1e;">
                <!-- Terminal with Session Bar -->
                <VBox style="-fx-background-color: #0a0a0a;">
                    <HBox spacing="0" prefHeight="32" minHeight="32" style="-fx-padding: 0; -fx-background-color: #252526; -fx-border-color: #3c3c3c; -fx-border-width: 0 0 1 0;">
                        <ScrollPane fitToHeight="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" styleClass="session-bar-scroll" HBox.hgrow="ALWAYS">
                            <HBox fx:id="sessionBar" spacing="0" alignment="CENTER_LEFT" prefHeight="32" minHeight="32" style="-fx-padding: 0; -fx-background-color: #252526;"/>
                        </ScrollPane>
                    </HBox>
                    <StackPane VBox.vgrow="ALWAYS" styleClass="terminal-surface">
                        <Region fx:id="terminalBackground" maxWidth="Infinity" maxHeight="Infinity"
                                mouseTransparent="true" styleClass="terminal-background"/>
                        <Region fx:id="terminalOverlay" maxWidth="Infinity" maxHeight="Infinity"
                                mouseTransparent="true" styleClass="terminal-overlay"/>
                        <TextArea fx:id="terminalOutput" editable="false" wrapText="true"
                                  maxWidth="Infinity" maxHeight="Infinity" styleClass="terminal-output"/>
                    </StackPane>
                    <HBox spacing="0" alignment="CENTER_LEFT" style="-fx-padding: 6 10; -fx-background-color: #0c0c0c; -fx-border-color: #3c3c3c; -fx-border-width: 1 0 0 0;">
                        <StackPane HBox.hgrow="ALWAYS" styleClass="terminal-input-wrap">
                            <TextField fx:id="commandInput" onAction="#sendCommand" promptText="> " prefHeight="34" StackPane.alignment="CENTER_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #e6e6e6; -fx-font-family: 'Cascadia Code', 'Consolas', 'Microsoft YaHei', monospace; -fx-font-size: 14px; -fx-border-color: transparent; -fx-background-radius: 6; -fx-padding: 8 10; -fx-prompt-text-fill: #555;"/>
                        </StackPane>
                        <!-- AI 终端操作状态指示器：AI 在终端打字/执行命令时显示，空闲时隐藏 -->
                        <Label fx:id="aiTerminalStatus" text="" visible="false" managed="false"
                               style="-fx-text-fill: #4a9eff; -fx-font-size: 12px; -fx-padding: 0 0 0 10; -fx-font-family: 'Microsoft YaHei', 'Segoe UI Emoji', sans-serif;">
                        </Label>
                    </HBox>
                </VBox>

                <!-- File Manager with Tree + Table -->
                <SplitPane fx:id="fileSplitPane" dividerPositions="0.22" orientation="HORIZONTAL"
                           style="-fx-background-color: #1e1e1e;">
                    <!-- Left: Directory Tree -->
                    <VBox style="-fx-background-color: #252526; -fx-border-color: #3c3c3c; -fx-border-width: 0 1 0 0;">
                        <HBox spacing="2" style="-fx-padding: 5; -fx-background-color: #2d2d2d; -fx-border-color: #3c3c3c; -fx-border-width: 0 0 1 0;">
                            <Label text="%files.title" style="-fx-text-fill: #d4d4d4; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="⟳" onAction="#refreshDirTree" styleClass="small-btn"/>
                        </HBox>
                        <TreeView fx:id="dirTree" VBox.vgrow="ALWAYS"
                                  style="-fx-background-color: #252526; -fx-control-inner-background: #252526;"/>
                    </VBox>

                    <!-- Right: File Table -->
                    <VBox style="-fx-background-color: #1e1e1e;">
                        <HBox spacing="2" fx:id="breadcrumbBar" style="-fx-padding: 5; -fx-background-color: #252526;">
                            <Button text="/" onAction="#navigateToPathRoot" styleClass="breadcrumb-btn"/>
                        </HBox>
                        <HBox spacing="2" style="-fx-padding: 3 5; -fx-background-color: #252526; -fx-border-color: #3c3c3c; -fx-border-width: 0 0 1 0;">
                            <Button text="◀" onAction="#navigateToParent" styleClass="small-btn"/>
                            <Button text="/" onAction="#navigateToPathRoot" styleClass="small-btn"/>
                            <Separator orientation="VERTICAL" style="-fx-padding: 0 2;"/>
                            <Button text="⬆" onAction="#uploadFile" styleClass="sftp-btn"/>
                            <Button text="⬇" onAction="#downloadFile" styleClass="sftp-btn"/>
                            <Button text="⟳" onAction="#refreshFiles" styleClass="sftp-btn"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button text="📁+" onAction="#createFolder" styleClass="sftp-btn"/>
                            <Button text="📄+" onAction="#createFile" styleClass="sftp-btn"/>
                            <Button text="🗑" onAction="#deleteFile" styleClass="sftp-btn"/>
                        </HBox>
                        <TableView fx:id="fileTable" VBox.vgrow="ALWAYS" style="-fx-background-color: #1e1e1e;" tableMenuButtonVisible="false">
                            <columns>
                                <TableColumn fx:id="fileNameCol" text="%files.col.name" prefWidth="260"/>
                                <TableColumn fx:id="fileSizeCol" text="%files.col.size" prefWidth="80"/>
                                <TableColumn fx:id="fileTypeCol" text="%files.col.type" prefWidth="90"/>
                                <TableColumn fx:id="fileTimeCol" text="%files.col.time" prefWidth="140"/>
                                <TableColumn fx:id="filePermCol" text="%files.col.perm" prefWidth="100"/>
                                <TableColumn fx:id="fileOwnerCol" text="%files.col.owner" prefWidth="100"/>
                            </columns>
                        </TableView>
                    </VBox>
                </SplitPane>
            </SplitPane>

            <!-- ===== Right Panel: AI Chat / Live terminal copilot ===== -->
            <VBox fx:id="rightPanel" prefWidth="430" minWidth="0" spacing="0" styleClass="ai-panel">
                <VBox fx:id="rightContent" VBox.vgrow="ALWAYS" spacing="0" styleClass="ai-panel">

                    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="ai-panel-header">
                        <StackPane styleClass="ai-header-logo">
                            <Label text="✦" styleClass="ai-header-logo-glyph"/>
                        </StackPane>
                        <VBox spacing="1">
                            <Label text="%ai.title" styleClass="ai-panel-title"/>
                            <Label text="%ai.live_terminal" styleClass="ai-panel-subtitle"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="aiActivityIndicator" text="%ai.activity_ready" styleClass="ai-activity-pill ai-activity-ready"/>
                        <Button fx:id="aiNewChatBtn" text="+" onAction="#newAiChat" styleClass="ai-top-btn"/>
                        <Button fx:id="aiHistoryBtn" text="◷" onAction="#showAiHistory" styleClass="ai-top-btn"/>
                        <Button fx:id="aiSettingsBtn" text="⚙" onAction="#showAiSettings" styleClass="ai-top-btn"/>
                    </HBox>

                    <StackPane fx:id="aiChatStack" minHeight="0" VBox.vgrow="ALWAYS" styleClass="ai-chat-stage">
                        <VBox fx:id="aiWelcomeScreen" minHeight="0" alignment="CENTER" spacing="10" styleClass="ai-welcome-screen">
                            <Region prefHeight="4"/>
                            <StackPane styleClass="ai-welcome-orbit">
                                <Label text="✦" styleClass="ai-welcome-glyph"/>
                            </StackPane>
                            <Label text="%ai.welcome_title" styleClass="ai-welcome-title"/>
                            <Label text="%ai.welcome_subtitle" wrapText="true" maxWidth="330" alignment="CENTER" styleClass="ai-welcome-subtitle"/>
                            <HBox spacing="7" alignment="CENTER" styleClass="ai-live-explainer">
                                <Label text="●" styleClass="ai-live-dot"/>
                                <Label text="%ai.live_explainer" styleClass="ai-live-explainer-text"/>
                            </HBox>
                            <VBox spacing="8" maxWidth="340" styleClass="ai-quick-actions">
                                <Button text="%ai.quick_analyze" onAction="#aiAnalyzeServer" maxWidth="Infinity" styleClass="ai-quick-action"/>
                                <Button text="%ai.quick_services" onAction="#aiCheckServices" maxWidth="Infinity" styleClass="ai-quick-action"/>
                                <Button text="%ai.quick_deploy" onAction="#generateDeployScript" maxWidth="Infinity" styleClass="ai-quick-action"/>
                            </VBox>
                        </VBox>

                        <ScrollPane fx:id="aiChatScroll" minHeight="0" fitToWidth="true" visible="false" managed="false" styleClass="ai-chat-scroll">
                            <VBox fx:id="aiChatMessages" spacing="14" styleClass="ai-chat-messages"/>
                        </ScrollPane>
                    </StackPane>

                    <VBox spacing="0" styleClass="ai-composer-shell">
                        <FlowPane fx:id="fileReferences" vgap="4" hgap="6" visible="false" managed="false" styleClass="ai-file-references"/>
                        <VBox spacing="0" styleClass="ai-input-wrap">
                            <TextArea fx:id="aiInput" prefHeight="72" wrapText="true" promptText="%ai.input_prompt" styleClass="ai-composer-input"/>
                            <HBox spacing="8" alignment="CENTER_LEFT" styleClass="ai-composer-controls">
                                <ComboBox fx:id="modelSelector" prefWidth="135" prefHeight="30" styleClass="ai-combo"/>
                                <Button fx:id="aiModelConfigBtn" text="⚙" onAction="#showCustomModelConfig" styleClass="ai-composer-icon-btn" prefHeight="30"/>
                                <Button fx:id="aiUploadBtn" text="＋" onAction="#attachFilesToAi" styleClass="ai-composer-icon-btn" prefHeight="30"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="aiSendBtn" text="%ai.send" onAction="#handleSendOrStop" prefHeight="36" minWidth="76" styleClass="ai-send-btn"/>
                            </HBox>
                        </VBox>
                        <HBox spacing="8" alignment="CENTER_LEFT" styleClass="ai-composer-meta">
                            <Label fx:id="aiConnectionIndicator" text="%ai.connected" styleClass="ai-conn-indicator"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label text="%ai.input_hint" styleClass="ai-input-hint"/>
                        </HBox>
                    </VBox>

                </VBox>
            </VBox>

        </SplitPane>
    </center>

    <!-- ========== Bottom Status Bar ========== -->
    <bottom>
        <HBox style="-fx-background-color: #007acc; -fx-padding: 4 10;">
            <Label fx:id="statusText" text="%status.ready" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="serverInfo" text="" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
            <Separator orientation="VERTICAL" style="-fx-padding: 0 8;"/>
            <Label fx:id="modelInfo" text="" style="-fx-text-fill: white; -fx-font-size: 11px;"/>
        </HBox>
    </bottom>

</BorderPane>
